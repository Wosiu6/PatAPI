@page "/ballsimulation"

@using AvnCanvasHelper;
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using Infrastructure.Models.Physics;
@using System.Drawing;
@using PatSite.Server.Models;
@using Infrastructure.Constants;

<div>
    <label>Time Step</label>
    <input class="mx-3" type="range" min="0.1" max="5" step="0.01" @bind=PhysicalConstants.TimeStep @bind:event="oninput" />
    <span class="ms-4">@PhysicalConstants.TimeStep</span>
</div>

<div>
    <label>Min Speed</label>
    <input class="mx-3" type="range" min="1" max="50" step="1" @bind=PhysicalConstants.MinimumSpeed @bind:event="oninput" />
    <span class="ms-4">@PhysicalConstants.MinimumSpeed</span>
</div>

<div>
    <label>Max Speed</label>
    <input class="mx-3" type="range" min="5" max="100" step="1" @bind=PhysicalConstants.MaximumSpeed @bind:event="oninput" />
    <span class="ms-4">@PhysicalConstants.MaximumSpeed</span>
</div>

<div>
    <label>Wall Elasticity</label>
    <input class="mx-3" type="range" min="0" max="1" step="0.01" @bind=PhysicalConstants.WallElasticity @bind:event="oninput" />
    <span class="ms-4">@PhysicalConstants.WallElasticity</span>
</div>

<div>
    <button @onclick="ClearBalls">Clear Rolling Balls</button>
    <button @onclick="BallField.AddRandmBall">Add Random Ball</button>
</div>

<CanvasHelper @ref="CanvasHelper"
              CanvasResized="CanvasResized"
              RenderFrame="RenderFrame"
              MouseDown="MouseDown"
              MouseUp="MouseUp"
              MouseMove="MouseMove">

    <BECanvas @ref="CanvasReference"></BECanvas>

</CanvasHelper>

@code{
    private Canvas BallField = new Canvas();
    private Canvas2DContext canvasContext;
    private BECanvasComponent CanvasReference;
    private CanvasHelper CanvasHelper;
    private Size Size = new Size();
    private double FPS;
    private DateTime LastRender;

    public ConstantsChangeModel? Model;

    protected override void OnInitialized() => Model ??= new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Create the canvas and context
            canvasContext = await CanvasReference.CreateCanvas2DAsync();
            // Initialize the helper
            await CanvasHelper.Initialize();
        }
    }

    public async Task RenderFrame(double fps)
    {
        FPS = fps;

        foreach (Ball ball in BallField.Balls)
        {
            ball.Move(BallField.Width, BallField.Height);
        }

        await UpdateBackground();

        await UpdateBalls();

        await ClearOutterBackground();

    }

    private async Task UpdateBackground()
    {
        await this.canvasContext.BeginBatchAsync();

        await this.canvasContext.ClearRectAsync(0, 0, BallField.Width, BallField.Height);
        await this.canvasContext.SetFillStyleAsync("#003366");
        await this.canvasContext.FillRectAsync(0, 0, BallField.Width, BallField.Height);
        await this.canvasContext.SetFontAsync("26px Segoe UI");
        await this.canvasContext.SetFillStyleAsync("#FFFFFF");
        await this.canvasContext.FillTextAsync("Pat ball simulation in HTML Canvas", 10, 30);
        await this.canvasContext.SetFontAsync("16px consolas");
        await this.canvasContext.FillTextAsync($"FPS: {FPS:0.000}", 10, 50);

        await this.canvasContext.EndBatchAsync();
    }

    private async Task ClearOutterBackground()
    {
        await this.canvasContext.BeginBatchAsync();

        await this.canvasContext.ClearRectAsync(BallField.Width, BallField.Height, -BallField.Width, BallConstants.MaxRadius);
        await this.canvasContext.ClearRectAsync(BallField.Width, BallField.Height, BallConstants.MaxRadius, -BallField.Height);
        await this.canvasContext.ClearRectAsync(BallField.Width, BallField.Height, BallConstants.MaxRadius, BallConstants.MaxRadius);

        await this.canvasContext.EndBatchAsync();
    }

    private async Task UpdateBalls()
    {
        foreach (Ball ball in BallField.Balls)
        {
            await this.canvasContext.BeginBatchAsync();

            await this.canvasContext.SetStrokeStyleAsync("#FF0000");
            await this.canvasContext.BeginPathAsync();
            await this.canvasContext.ArcAsync(ball.X, ball.Y, ball.Radius, 0, 2 * Math.PI, false);
            await this.canvasContext.SetFillStyleAsync(ball.Color);
            await this.canvasContext.FillAsync();
            await this.canvasContext.StrokeAsync();

            await this.canvasContext.EndBatchAsync();
        }
        CanvasResized(Size);
    }

    /// <summary>
    /// Called by CanvasHelper whenever the browser is resized.
    /// </summary>
    /// <param name="size"></param>
    public void CanvasResized(Size size)
    {
        Size = size;
        BallField.Resize(size.Width * 0.6, size.Height * 0.6);
    }

    // Handle mouse down events
    void MouseDown(CanvasMouseArgs args)
    {
    }

    // Handle mouse up events
    void MouseUp(CanvasMouseArgs args)
    {

    }

    // Handle mouse move events
    void MouseMove(CanvasMouseArgs args)
    {

    }

    private async Task ClearBalls() => BallField.Balls.RemoveAll(b => b.IsRolling);
}